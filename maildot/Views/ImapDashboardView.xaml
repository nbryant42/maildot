<UserControl
    x:Class="maildot.Views.ImapDashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:maildot.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:maildot.ViewModels"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:maildot.Converters"
    mc:Ignorable="d" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:SuggestionToBrushConverter x:Key="SuggestionToBrushConverter" />
        <conv:LabelNamesTooltipConverter x:Key="LabelNamesTooltipConverter" />
        <conv:LabelCountToVisibilityConverter x:Key="LabelCountToVisibilityConverter" />
        <conv:UnreadCountToFontWeightConverter x:Key="UnreadCountToFontWeightConverter" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
    </UserControl.Resources>

    <Grid MinWidth="1050"
          MinHeight="600"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollView Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">
            <StackPanel Padding="16">
                <StackPanel Visibility="{Binding IsSearchActive, Converter={StaticResource BoolToVisibilityConverter}}"
                        Spacing="8"
                        Margin="0,0,0,12">
                    <Grid ColumnSpacing="8" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <!-- label -->
                            <ColumnDefinition Width="*"/>
                            <!-- X button -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Search Results" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                            Click="OnClearSearchClicked"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTipService.ToolTip="Clear search"
                            Margin="0,0,8,0">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                                <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                            </Button.Resources>
                            <Path Data="M3 3 L13 13 M13 3 L3 13"
                              Stroke="{ThemeResource TextFillColorSecondaryBrush}"
                              StrokeThickness="1.5"/>
                        </Button>
                    </Grid>
                    <ListView ItemsSource="{Binding SearchItems}"
                          SelectedItem="{Binding SelectedSearchItem, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:SearchNavItemViewModel">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch" Spacing="8">
                                    <TextBlock Text="{x:Bind DisplayName}" Width="150" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
                <TextBlock Text="Folders" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TreeView x:Name="FoldersTree"
                      ItemsSource="{Binding Folders}"
                      SelectionMode="Single"
                      ItemInvoked="OnFolderInvoked"
                      ContextRequested="OnFoldersContextRequested">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:MailFolderViewModel">
                            <TreeViewItem>
                                <Grid ColumnSpacing="8" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                           Text="{x:Bind DisplayName}"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Stretch" />
                                    <TextBlock Grid.Column="1"
                                           Text="{x:Bind UnreadCount, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Right"
                                           FontWeight="{x:Bind UnreadCount, Mode=OneWay, Converter={StaticResource UnreadCountToFontWeightConverter}}" />
                                </Grid>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <Grid Margin="0,16,0,8" ColumnSpacing="8" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Labels" FontSize="18" FontWeight="SemiBold" />
                    <Button Grid.Column="1"
                        Click="OnAddRootLabelClicked"
                        Background="Transparent"
                        BorderThickness="0"
                        ToolTipService.ToolTip="Add label">
                        <FontIcon Glyph="&#xE710;" />
                    </Button>
                </Grid>
                <TreeView x:Name="LabelsTree"
                      ItemsSource="{Binding Labels}"
                      SelectionMode="Single"
                      ItemInvoked="OnLabelInvoked"
                      ContextRequested="OnLabelsContextRequested"
                      AllowDrop="True"
                      DragEnter="OnLabelDragEnter"
                      DragOver="OnLabelDragOver"
                      DragLeave="OnLabelDragLeave"
                      Drop="OnLabelDrop">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:LabelViewModel">
                            <TreeViewItem ItemsSource="{x:Bind Children}"
                                      AllowDrop="True"
                                      DragEnter="OnLabelDragEnter"
                                      DragLeave="OnLabelDragLeave"
                                      DragOver="OnLabelDragOver"
                                      Drop="OnLabelDrop">
                                <Grid ColumnSpacing="8"
                                      HorizontalAlignment="Stretch"
                                      AllowDrop="True"
                                      DragEnter="OnLabelDragEnter"
                                      DragOver="OnLabelDragOver"
                                      DragLeave="OnLabelDragLeave"
                                      Drop="OnLabelDrop">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                           Text="{x:Bind Name}"
                                           TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Stretch" />
                                    <TextBlock Grid.Column="1"
                                           Text="{x:Bind UnreadCount, Mode=OneWay}"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           Visibility="{x:Bind UnreadCount, Mode=OneWay, Converter={StaticResource LabelCountToVisibilityConverter}}" />
                                    <Button Grid.Column="2"
                                        Click="OnAddChildLabelClicked"
                                        Tag="{x:Bind Id}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Right"
                                        ToolTipService.ToolTip="Add child label">
                                        <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                    </Button>
                                </Grid>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </StackPanel>
        </ScrollView>

        <Grid Grid.Column="1" Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="6">
                <TextBlock Text="{Binding AccountSummary}" FontSize="18" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentFolderTitle}"
                               FontSize="20"
                               FontWeight="SemiBold" />
                    <ProgressRing Width="24" Height="24" IsActive="{Binding IsBusy}" />
                    <CheckBox Content="{Binding ActiveFilterLabel}"
                          IsChecked="{Binding ActiveFilterOnly, Mode=TwoWay}"
                          Checked="OnUnlabeledOnlyToggled"
                          Unchecked="OnUnlabeledOnlyToggled"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Retry"
                            Margin="0,4,0,0"
                            Visibility="{Binding RetryVisibility}"
                            Click="OnRetryClicked"
                            HorizontalAlignment="Left" />
                    <Button x:Name="SettingsButton"
                            Click="OnSettingsClicked"
                            HorizontalAlignment="Left"
                            ToolTipService.ToolTip="Open settings">
                        <FontIcon Glyph="&#xE713;" />
                    </Button>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="16,0,0,0">
                        <Button Content="Compose" Click="OnComposeClicked" />
                        <Button Content="Reply" Click="OnReplyClicked" />
                        <Button Content="Reply all" Click="OnReplyAllClicked" />
                        <Button Content="Forward" Click="OnForwardClicked" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1" Padding="0" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                <Grid>
                    <ListView x:Name="MessagesList"
                              ItemsSource="{Binding Messages}"
                              SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                              CanDragItems="True"
                              DragItemsStarting="OnMessagesDragItemsStarting"
                              KeyDown="OnMessagesListKeyDown"
                              SelectionChanged="OnMessagesSelectionChanged"
                              Loaded="OnMessagesListLoaded"
                              ContextRequested="OnMessagesContextRequested">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:EmailMessageViewModel">
                                <Border Background="{Binding SuggestionScore, Converter={StaticResource SuggestionToBrushConverter}}"
                                        Padding="8"
                                        CornerRadius="6">
                                    <Grid Padding="4" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0"
                                                 Width="10"
                                                 Height="10"
                                                 Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                                 VerticalAlignment="Center"
                                                 Opacity="{Binding IsUnread, Converter={StaticResource BoolToOpacityConverter}}" />

                                        <Grid Grid.Column="1" Width="36" Height="36">
                                            <Ellipse>
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{x:Bind SenderColor}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock Text="{x:Bind SenderInitials}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <StackPanel Grid.Column="2" Spacing="4">
                                            <TextBlock Text="{x:Bind Subject}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Sender}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <TextBlock Text="{x:Bind ReceivedDisplay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{x:Bind Preview}" TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3"
                                                    Spacing="4"
                                                    VerticalAlignment="Top"
                                                    HorizontalAlignment="Right">
                                            <Border Visibility="{Binding IsSuggested, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2">
                                                <TextBlock Text="Suggested"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                            <Border Visibility="{Binding IsLocalOnly, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                    CornerRadius="4"
                                                    Padding="6,2"
                                                    ToolTipService.ToolTip="Local archive only (not on IMAP server)">
                                                <TextBlock Text="Local"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <FontIcon Grid.Column="3"
                                                  Glyph="&#xE932;"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                  VerticalAlignment="Top"
                                                  HorizontalAlignment="Right"
                                                  ToolTipService.ToolTip="{Binding LabelNames, Converter={StaticResource LabelNamesTooltipConverter}}"
                                                  Visibility="{Binding LabelNames.Count, Converter={StaticResource LabelCountToVisibilityConverter}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2" Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="MessageHeaderRow" Height="Auto" />
                <RowDefinition x:Name="MessageContentRow" Height="*" />
                <RowDefinition x:Name="AttachmentsHeaderRow" Height="0" />
                <RowDefinition x:Name="AttachmentsContentRow" Height="0" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>       <!-- headers -->
                    <ColumnDefinition Width="Auto"/>    <!-- date -->
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
                    <TextBlock Text="{Binding SelectedMessage.Subject}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{Binding SelectedMessage.ToDisplay}"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Visibility="{Binding SelectedMessage.HasTo, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding SelectedMessage.FromDisplay}"
                               FontSize="16"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedMessage.CcDisplay}"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Visibility="{Binding SelectedMessage.HasCc, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <TextBlock Text="{Binding SelectedMessage.BccDisplay}"
                               FontSize="16"
                               TextWrapping="Wrap"
                               Visibility="{Binding SelectedMessage.HasBcc, Converter={StaticResource BoolToVisibilityConverter}}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding SelectedMessage.ReceivedDisplay}"
                           FontSize="16"
                           HorizontalAlignment="Right" />
            </Grid>

            <controls:WebView2 x:Name="MessageWebView" Grid.Row="1"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />

            <TextBlock x:Name="AttachmentsHeader"
                       Grid.Row="2"
                       Text="Attachments"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,8,0,4"
                       Visibility="Collapsed" />
            
            <controls:WebView2 x:Name="AttachmentsWebView"
                                Grid.Row="3"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Visibility="Collapsed"/>
        </Grid>
    </Grid>
</UserControl>

